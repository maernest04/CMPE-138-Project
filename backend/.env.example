# Copy to .env and fill in your MySQL credentials:
#   cp .env.example .env
#
# Backend loads: backend/.env first, then repo-root .env (root overrides).

# --- MySQL (required for API + login) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=scv_user
DB_PASSWORD=scv_password
DB_NAME=senior_capstone_viewer

# If you use MySQL root instead, use e.g.:
# DB_USER=root
# DB_PASSWORD=your_root_password

# --- Server ---
PORT=4000

# Frontend origin (Vite default)
CORS_ORIGIN=http://localhost:5173

# Session cookie signing (change in production)
SESSION_SECRET=dev-only-change-in-production

# Max students per team (admin + student join/create). Frontend reads same value via GET /api/config.
# MAX_TEAM_MEMBERS=5
